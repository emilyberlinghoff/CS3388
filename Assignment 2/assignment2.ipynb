    "0                               & \\frac{\\operatorname{height}}{2}   & 0 & y_{min} + \\frac{\\operatorname{height}}{2} \\\\\n",
    "0                               & 0                                 & 1 & 0 \\\\\n",
    "0                               & 0                                 & 0 & 1\n",
    "\\end{array}\\right]\n",
    "$\n",
    "\n",
